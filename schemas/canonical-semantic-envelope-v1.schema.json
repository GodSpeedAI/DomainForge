{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://domainforge.dev/schemas/canonical-semantic-envelope-v1.schema.json",
  "title": "DomainForge Canonical Semantic Envelope Document",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "producer",
    "inputs",
    "self_hash",
    "semantic_closure_hash",
    "envelope"
  ],
  "properties": {
    "schema_version": { "const": "domainforge-semantic-envelope/v1" },
    "producer": { "$ref": "#/definitions/producer" },
    "inputs": { "$ref": "#/definitions/inputs" },
    "self_hash": { "$ref": "#/definitions/hash" },
    "semantic_closure_hash": { "$ref": "#/definitions/hash" },
    "envelope": { "$ref": "#/definitions/envelope" }
  },
  "definitions": {
    "hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "concept_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "application_symbol_id": { "type": "string", "minLength": 1 },
    "decimal": { "type": "string", "pattern": "^-?[0-9]+(\\.[0-9]+)?$" },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?(Z|\\+00:00)$"
    },
    "ast_expression": {
      "$comment": "Serialized domainforge-ast/v3 expression; validated by ast-v3.schema.json."
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_set_hash",
        "semantic_pack_set_hash",
        "language_schema_version",
        "interpretation_version"
      ],
      "properties": {
        "source_set_hash": { "$ref": "#/definitions/hash" },
        "semantic_pack_set_hash": { "$ref": "#/definitions/hash" },
        "language_schema_version": { "type": "string", "minLength": 1 },
        "interpretation_version": { "type": "string", "minLength": 1 }
      }
    },
    "envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "language_schema_version",
        "canonicalization_version",
        "compiler_interpretation_version",
        "modules",
        "import_graph",
        "namespace_bindings",
        "semantic_packs",
        "semantic_declarations",
        "resolved_references",
        "application_contract"
      ],
      "properties": {
        "language_schema_version": { "type": "string", "minLength": 1 },
        "canonicalization_version": { "type": "string", "minLength": 1 },
        "compiler_interpretation_version": { "type": "string", "minLength": 1 },
        "modules": {
          "type": "array",
          "items": { "$ref": "#/definitions/module_ref" }
        },
        "import_graph": {
          "type": "array",
          "items": { "$ref": "#/definitions/import_edge" }
        },
        "namespace_bindings": {
          "type": "array",
          "items": { "$ref": "#/definitions/namespace_binding" }
        },
        "semantic_packs": {
          "type": "array",
          "items": { "$ref": "#/definitions/semantic_pack_ref" }
        },
        "semantic_declarations": {
          "type": "array",
          "items": { "$ref": "#/definitions/semantic_declaration" }
        },
        "resolved_references": {
          "type": "array",
          "items": { "$ref": "#/definitions/resolved_reference" }
        },
        "application_contract": { "$ref": "#/definitions/application_contract" }
      }
    },
    "module_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["logical_id", "semantic_content_hash", "namespace"],
      "properties": {
        "logical_id": { "type": "string", "minLength": 1 },
        "semantic_content_hash": { "$ref": "#/definitions/hash" },
        "namespace": { "type": "string", "minLength": 1 }
      }
    },
    "import_edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["importer", "imported"],
      "properties": {
        "importer": { "type": "string", "minLength": 1 },
        "imported": { "type": "string", "minLength": 1 }
      }
    },
    "namespace_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["namespace", "logical_id"],
      "properties": {
        "namespace": { "type": "string", "minLength": 1 },
        "logical_id": { "type": "string", "minLength": 1 }
      }
    },
    "semantic_pack_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pack_id", "content_hash"],
      "properties": {
        "pack_id": { "type": "string", "minLength": 1 },
        "content_hash": { "$ref": "#/definitions/hash" }
      }
    },
    "declaration_id": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "concept" },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id"],
              "properties": { "id": { "$ref": "#/definitions/concept_id" } }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "application" },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id"],
              "properties": {
                "id": { "$ref": "#/definitions/application_symbol_id" }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "occurrence" },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind", "content_hash", "duplicate_index"],
              "properties": {
                "kind": { "type": "string", "minLength": 1 },
                "content_hash": { "$ref": "#/definitions/hash" },
                "duplicate_index": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 4294967295
                }
              }
            }
          }
        }
      ]
    },
    "reference_target": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "declaration" },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id"],
              "properties": { "id": { "$ref": "#/definitions/declaration_id" } }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "namespace" },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["exact_name", "logical_module_id"],
              "properties": {
                "exact_name": { "type": "string", "minLength": 1 },
                "logical_module_id": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      ]
    },
    "semantic_declaration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "logical_module_id", "declaration"],
      "properties": {
        "id": { "$ref": "#/definitions/declaration_id" },
        "logical_module_id": { "type": "string", "minLength": 1 },
        "declaration": { "$ref": "#/definitions/semantic_payload" }
      }
    },
    "resolved_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "field_path", "target"],
      "properties": {
        "source": { "$ref": "#/definitions/declaration_id" },
        "field_path": { "type": "string", "minLength": 1 },
        "target": { "$ref": "#/definitions/reference_target" }
      }
    },
    "annotations": { "type": "object" },
    "semantic_payload": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "dimension" },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name"],
              "properties": { "name": { "type": "string", "minLength": 1 } }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "unit" },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["symbol", "dimension", "factor", "base_unit"],
              "properties": {
                "symbol": { "type": "string", "minLength": 1 },
                "dimension": { "$ref": "#/definitions/reference_target" },
                "factor": { "$ref": "#/definitions/decimal" },
                "base_unit": { "type": "string", "minLength": 1 }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "record" },
            "data": { "$ref": "#/definitions/record_contract" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "enum" },
            "data": { "$ref": "#/definitions/enum_contract" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "operation" },
            "data": { "$ref": "#/definitions/operation_contract" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "entity" },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "annotations"],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "version": { "type": "string" },
                "domain": { "type": "string" },
                "annotations": { "$ref": "#/definitions/annotations" },
                "contract": { "$ref": "#/definitions/entity_contract" }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "resource" },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "annotations"],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "unit": { "$ref": "#/definitions/reference_target" },
                "domain": { "type": "string" },
                "annotations": { "$ref": "#/definitions/annotations" }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "flow" },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["resource", "from_entity", "to_entity", "annotations"],
              "properties": {
                "resource": { "$ref": "#/definitions/reference_target" },
                "from_entity": { "$ref": "#/definitions/reference_target" },
                "to_entity": { "$ref": "#/definitions/reference_target" },
                "quantity": { "$ref": "#/definitions/decimal" },
                "annotations": { "$ref": "#/definitions/annotations" }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "pattern" },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "regex"],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "regex": { "type": "string" }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "role" },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name"],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "domain": { "type": "string" }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "relation" },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "subject_role", "predicate", "object_role"],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "subject_role": { "$ref": "#/definitions/reference_target" },
                "predicate": { "type": "string", "minLength": 1 },
                "object_role": { "$ref": "#/definitions/reference_target" },
                "via_flow": { "$ref": "#/definitions/reference_target" }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "instance" },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "entity_type", "fields"],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "entity_type": { "$ref": "#/definitions/reference_target" },
                "fields": {
                  "type": "object",
                  "additionalProperties": {
                    "$ref": "#/definitions/ast_expression"
                  }
                }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "policy" },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "metadata", "expression"],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "version": { "type": "string" },
                "metadata": { "type": "object" },
                "expression": { "$ref": "#/definitions/ast_expression" }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "concept_change" },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "name",
                "from_version",
                "to_version",
                "migration_policy",
                "breaking_change"
              ],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "from_version": { "type": "string", "minLength": 1 },
                "to_version": { "type": "string", "minLength": 1 },
                "migration_policy": { "type": "string", "minLength": 1 },
                "breaking_change": { "type": "boolean" }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "metric" },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "expression", "metadata"],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "expression": { "$ref": "#/definitions/ast_expression" },
                "metadata": { "type": "object" }
              }
            }
          }
        }
      ]
    },
    "application_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enums", "records", "entities", "operations"],
      "properties": {
        "enums": {
          "type": "array",
          "items": { "$ref": "#/definitions/enum_contract" }
        },
        "records": {
          "type": "array",
          "items": { "$ref": "#/definitions/record_contract" }
        },
        "entities": {
          "type": "array",
          "items": { "$ref": "#/definitions/entity_contract" }
        },
        "operations": {
          "type": "array",
          "items": { "$ref": "#/definitions/operation_contract" }
        }
      }
    },
    "enum_member": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "wire"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "wire": { "type": "string", "minLength": 1 }
      }
    },
    "enum_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "members"],
      "properties": {
        "id": { "$ref": "#/definitions/application_symbol_id" },
        "name": { "type": "string", "minLength": 1 },
        "members": {
          "type": "array",
          "items": { "$ref": "#/definitions/enum_member" }
        }
      }
    },
    "record_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "fields"],
      "properties": {
        "id": { "$ref": "#/definitions/application_symbol_id" },
        "name": { "type": "string", "minLength": 1 },
        "fields": {
          "type": "array",
          "items": { "$ref": "#/definitions/field_contract" }
        }
      }
    },
    "entity_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["concept_id", "name", "key_field", "fields"],
      "properties": {
        "concept_id": { "$ref": "#/definitions/concept_id" },
        "name": { "type": "string", "minLength": 1 },
        "key_field": { "type": "string", "minLength": 1 },
        "fields": {
          "type": "array",
          "items": { "$ref": "#/definitions/field_contract" }
        }
      }
    },
    "field_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "field_type", "optional", "constraints"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "field_type": { "$ref": "#/definitions/field_type" },
        "optional": { "type": "boolean" },
        "constraints": {
          "type": "array",
          "items": { "$ref": "#/definitions/field_constraint" }
        },
        "default": { "$ref": "#/definitions/typed_value" }
      }
    },
    "field_type": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "scalar" },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["scalar"],
              "properties": {
                "scalar": {
                  "enum": ["string", "int", "decimal", "bool", "timestamp", "uuid"]
                }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "quantity" },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["unit"],
              "properties": { "unit": { "$ref": "#/definitions/concept_id" } }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "entity_ref" },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["entity"],
              "properties": { "entity": { "$ref": "#/definitions/concept_id" } }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "enum" },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["symbol"],
              "properties": {
                "symbol": { "$ref": "#/definitions/application_symbol_id" }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "list" },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["element"],
              "properties": { "element": { "$ref": "#/definitions/field_type" } }
            }
          }
        }
      ]
    },
    "bounded_length": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
    "field_constraint": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "enum": ["min", "max", "exclusive_min", "exclusive_max"] },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["value"],
              "properties": { "value": { "$ref": "#/definitions/decimal" } }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": {
              "enum": ["min_length", "max_length", "min_items", "max_items"]
            },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["value"],
              "properties": { "value": { "$ref": "#/definitions/bounded_length" } }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "pattern" },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["pattern"],
              "properties": { "pattern": { "$ref": "#/definitions/concept_id" } }
            }
          }
        }
      ]
    },
    "typed_value": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "string" },
            "data": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "int" },
            "data": { "type": "integer" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "decimal" },
            "data": { "$ref": "#/definitions/decimal" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "bool" },
            "data": { "type": "boolean" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "timestamp" },
            "data": { "$ref": "#/definitions/timestamp" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "uuid" },
            "data": { "$ref": "#/definitions/concept_id" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "quantity" },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["base_value", "unit"],
              "properties": {
                "base_value": { "$ref": "#/definitions/decimal" },
                "unit": { "$ref": "#/definitions/concept_id" }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "entity_ref" },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["entity", "key"],
              "properties": {
                "entity": { "$ref": "#/definitions/concept_id" },
                "key": { "$ref": "#/definitions/typed_value" }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "enum" },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["symbol", "wire"],
              "properties": {
                "symbol": { "$ref": "#/definitions/application_symbol_id" },
                "wire": { "type": "string", "minLength": 1 }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "list" },
            "data": {
              "type": "array",
              "items": { "$ref": "#/definitions/typed_value" }
            }
          }
        }
      ]
    },
    "actor_ref": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": { "kind": { "const": "anonymous" } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "role" },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["role"],
              "properties": { "role": { "$ref": "#/definitions/concept_id" } }
            }
          }
        }
      ]
    },
    "policy_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy", "enforcement_point", "failure_code"],
      "properties": {
        "policy": { "$ref": "#/definitions/concept_id" },
        "enforcement_point": { "const": "precondition" },
        "failure_code": { "type": "string", "minLength": 1 }
      }
    },
    "access_mode": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": { "kind": { "const": "public" } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "policy_governed" },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["bindings"],
              "properties": {
                "bindings": {
                  "type": "array",
                  "items": { "$ref": "#/definitions/policy_binding" }
                }
              }
            }
          }
        }
      ]
    },
    "failure_kind": {
      "enum": [
        "input_validation",
        "policy",
        "missing_state",
        "idempotency_conflict",
        "concurrency_conflict"
      ]
    },
    "failure_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "kinds", "meaning"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "kinds": {
          "type": "array",
          "items": { "$ref": "#/definitions/failure_kind" }
        },
        "meaning": { "type": "string", "minLength": 1 }
      }
    },
    "idempotency_strategy": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "keyed_by" },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["field"],
              "properties": { "field": { "type": "string", "minLength": 1 } }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": { "kind": { "const": "inherent" } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "const": "not_applicable" },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["explanation"],
              "properties": {
                "explanation": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      ]
    },
    "concurrency_strategy": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": { "enum": ["unique_key", "optimistic_version"] },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["field"],
              "properties": { "field": { "type": "string", "minLength": 1 } }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": { "kind": { "const": "read_snapshot" } }
        }
      ]
    },
    "operation_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "intent",
        "direction",
        "actor",
        "access",
        "input",
        "output",
        "state",
        "effect",
        "transaction",
        "failures",
        "idempotency",
        "concurrency",
        "evidence",
        "lifecycle"
      ],
      "properties": {
        "id": { "$ref": "#/definitions/application_symbol_id" },
        "name": { "type": "string", "minLength": 1 },
        "intent": { "type": "string", "minLength": 1 },
        "direction": { "enum": ["inbound", "outbound", "internal"] },
        "actor": { "$ref": "#/definitions/actor_ref" },
        "access": { "$ref": "#/definitions/access_mode" },
        "input": { "$ref": "#/definitions/application_symbol_id" },
        "output": { "$ref": "#/definitions/application_symbol_id" },
        "state": { "$ref": "#/definitions/concept_id" },
        "effect": { "enum": ["creates", "mutates", "reads"] },
        "transaction": { "enum": ["single_aggregate", "read_only"] },
        "failures": {
          "type": "array",
          "items": { "$ref": "#/definitions/failure_contract" }
        },
        "idempotency": { "$ref": "#/definitions/idempotency_strategy" },
        "concurrency": { "$ref": "#/definitions/concurrency_strategy" },
        "evidence": { "const": "operation_trace" },
        "lifecycle": { "const": "synchronous_request_response" }
      }
    }
  }
}
