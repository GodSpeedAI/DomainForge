{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://domainforge.ai/schemas/otel/semconv_registry.schema.json",
  "title": "DomainForge OTel SemConv registry (projection subset)",
  "description": "Structural schema for the OpenTelemetry semantic-convention registry emitted by `domainforge project --format otel-semconv`. This is the fixed subset DomainForge produces (attribute_group + span groups); it is used as the CI validation gate in place of a full `weaver registry check` (see docs/otel-projections.md for the rationale).",
  "type": "object",
  "required": ["groups"],
  "additionalProperties": false,
  "properties": {
    "groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          { "$ref": "#/definitions/attributeGroup" },
          { "$ref": "#/definitions/spanGroup" }
        ]
      }
    }
  },
  "definitions": {
    "attributeGroup": {
      "type": "object",
      "required": ["id", "type", "brief", "attributes"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "const": "attribute_group" },
        "brief": { "type": "string", "minLength": 1 },
        "attributes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/attributeDef" }
        }
      }
    },
    "attributeDef": {
      "type": "object",
      "required": ["id", "type", "stability", "brief"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": ["string", "int", "double", "boolean"]
        },
        "stability": {
          "type": "string",
          "enum": ["development", "stable", "experimental", "deprecated"]
        },
        "brief": { "type": "string", "minLength": 1 }
      }
    },
    "spanGroup": {
      "type": "object",
      "required": ["id", "type", "span_kind", "brief", "attributes"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "const": "span" },
        "span_kind": {
          "type": "string",
          "enum": ["internal", "producer", "consumer", "client", "server"]
        },
        "brief": { "type": "string", "minLength": 1 },
        "attributes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["ref"],
            "additionalProperties": false,
            "properties": { "ref": { "type": "string", "minLength": 1 } }
          }
        }
      }
    }
  }
}
