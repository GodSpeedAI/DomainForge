// Negative fixture: semantically broken SEA.
// Parses, but `domainforge validate` MUST reject it because the Flow endpoints
// and resource reference entities/resources that were never declared.

@namespace "procurement"
@version "1.0.0"

Entity "Buyer" in procurement

