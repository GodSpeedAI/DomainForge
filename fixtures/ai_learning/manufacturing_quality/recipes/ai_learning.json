{
  "name": "manufacturing_quality_ai_learning_v0",
  "authority_config": "../authority/environment.json",
  "projections": {
    "llm_dataset": {
      "enabled": true,
      "format": "chatml_jsonl",
      "families": [
        "authorization_qa",
        "policy_explanation",
        "counterexample_detection",
        "entity_lookup"
      ]
    },
    "graph_ml_dataset": {
      "enabled": true,
      "tasks": [
        "node_classification",
        "link_prediction",
        "policy_violation_detection"
      ]
    },
    "cep_eval_dataset": {
      "enabled": true,
      "families": ["AuthorityBench", "ConformanceBench"]
    }
  },
  "splits": { "train": 0.8, "validation": 0.1, "test": 0.1 },
  "seed": 0
}
